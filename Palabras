#esta bien la primera tarea aqui esta la segunda
vocales = ["a","e","i","o","u"]
voc = 0

palabra = input("Escribe una palabra random: ")

for letra in palabra:
    if letra.lower() in vocales:
        voc += 1

print("Número de vocales:", voc)
